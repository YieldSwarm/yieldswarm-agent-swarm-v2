# YieldSwarm Environment Variables
# Copy this file to .env and fill in your values. NEVER commit real secrets.

# === AKASH NETWORK ===
AKASH_NODE=https://rpc.akashnet.net:443
AKASH_CHAIN_ID=akashnet-2
AKASH_GAS=auto
AKASH_GAS_ADJUSTMENT=1.25
AKASH_GAS_PRICES=0.025uakt
AKASH_SIGN_MODE=amino-json
AKASH_KEY_NAME=yieldswarm-admin

# === HASHICORP / TERRAFORM CLOUD ===
TF_CLOUD_ORGANIZATION=HelixChainProd
TF_WORKSPACE=Helixchainprod
# HCP_TOKEN= your_hcp_token_here   # Set via `terraform login` or env, do not hardcode

# === GITHUB CONTAINER REGISTRY (handled by GitHub Actions - do not set manually) ===
# GHCR login uses GITHUB_TOKEN automatically

# === MULTI-CLOUD CREDENTIALS (store securely, never commit) ===
# RUNPOD_API_KEY=
# VULTR_API_KEY=
# DIGITALOCEAN_TOKEN=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_TENANT_ID=
# AZURE_SUBSCRIPTION_ID=
# GCP_PROJECT_ID=
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# === VERCEL (if using Vercel CLI) ===
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=   # for yieldswarm-v2.vercel.app

# === APP / TELEMETRY (example placeholders) ===
NEXT_PUBLIC_API_BASE_URL=https://yieldswarm-v2.vercel.app
OLLAMA_HOST=0.0.0.0
# Add any private RPC endpoints or TEE signing keys here if needed (use secret management)